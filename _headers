# Sohadot.com — Security Headers
# Works with: Cloudflare Pages, Netlify, or any CDN that supports _headers files
# NOTE: GitHub Pages ignores this file. To activate these headers, put the site
# behind a Cloudflare proxy (free plan) and mirror these rules there.

/*
  # Prevent clickjacking
  X-Frame-Options: SAMEORIGIN

  # Prevent MIME sniffing
  X-Content-Type-Options: nosniff

  # Referrer policy — privacy-friendly
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions policy — disable unnecessary browser features
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Content Security Policy
  # Allows: self, Google Fonts, Google Tag Manager / Analytics, Google AdSense
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://pagead2.googlesyndication.com https://*.adtrafficquality.google; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://pagead2.googlesyndication.com https://*.adtrafficquality.google; img-src 'self' data: https:; frame-src https://www.googletagmanager.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://*.adtrafficquality.google; frame-ancestors 'self';

  # HTTPS upgrade
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
